{
  "env": "testing",
  "mode": "slave",
  "server": {
    "port": 13500,
    "leader": "master:13420"
  },
  "cluster": {
    "node_id": "test-node",
    "discovery_mechanism": "static"
  },
  "log": {
    "formatter": "json",
    "level": "debug"
  },
  "service": {
    "id": "org.horde.Test"
  },
  "project": {
    "workspace_dir": "/tmp/test-workspace",
    "context_retention": 120
  },
  "paths": {
    "config_dir": "/tmp/horde-config",
    "data_dir": "/tmp/horde-data",
    "state_dir": "/tmp/horde-state"
  }
}
